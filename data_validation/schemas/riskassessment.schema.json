{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Risk Assessment Dataset Entry",
  "type": "object",
  "required": ["assessment_id", "deployment_scenario", "components_assessed", "dsgai_risks_identified"],
  "properties": {
    "assessment_id": { "type": "string", "pattern": "^RA-\\d{4}$" },
    "deployment_scenario": { "type": "string", "minLength": 20 },
    "components_assessed": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "dsgai_risks_identified": { "type": "array", "items": { "type": "object", "required": ["dsgai_id", "risk_rating"], "properties": { "dsgai_id": { "type": "string", "pattern": "^DSGAI(0[1-9]|1[0-9]|2[01])$" }, "risk_rating": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] } } }, "minItems": 1 },
    "existing_controls": { "type": "string" },
    "control_gaps": { "type": "string" },
    "framework_alignment": { "type": "array", "items": { "type": "string" } },
    "industry": { "type": "string" }
  }
}
