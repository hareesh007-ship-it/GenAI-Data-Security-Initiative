{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Incident Dataset Entry",
  "type": "object",
  "required": ["incident_id", "date", "summary", "dsgai_mapping", "attack_vector", "data_types_affected", "impact"],
  "properties": {
    "incident_id": { "type": "string", "pattern": "^INC-\\d{4}$" },
    "date": { "type": "string", "format": "date" },
    "summary": { "type": "string", "minLength": 30 },
    "dsgai_mapping": { "type": "array", "items": { "type": "string", "pattern": "^DSGAI(0[1-9]|1[0-9]|2[01])$" }, "minItems": 1 },
    "attack_vector": { "type": "string" },
    "data_types_affected": { "type": "array", "items": { "type": "string", "enum": ["pii", "phi", "credentials", "ip", "model_weights", "embeddings", "system_prompts", "financial", "other"] }, "minItems": 1 },
    "root_cause": { "type": "string" },
    "impact": { "type": "string", "minLength": 10 },
    "detection_method": { "type": "string" },
    "mitigations_applied": { "type": "string" },
    "source": { "type": "string" },
    "industry": { "type": "string" }
  }
}
